# Secrets — never commit
.env
.env.*
!.env.example
*.key
*.pem
secrets.*

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
dist/
build/

# Node / frontend
node_modules/
frontend/dist/
frontend/coverage/
.vite/
*.tsbuildinfo

# Playwright
test-results/
playwright-report/
playwright/.cache/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Harness transient state
.claude/scheduled_tasks.lock

# Local screen recordings (convert to demo/*.gif, do not commit the raw video)
*.mov
*.mp4
*.m4v
