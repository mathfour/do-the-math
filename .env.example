# Copy to .env (gitignored) and fill in your own values.
# The Anthropic key is also enterable in the UI on first run; this .env is a
# convenience fallback for local dev / live testing. Never commit your real key.

# Your Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Model used for Math Intent extraction (override to swap models)
ANTHROPIC_MODEL=claude-sonnet-4-6
